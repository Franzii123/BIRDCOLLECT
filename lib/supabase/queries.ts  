// lib/supabase/queries.ts

export async function getSightings(userId: string) {
  const { data } = await supabase
    .from('sightings')
    .select('*')
    .eq('user_id', userId)
    .order('date_seen', { ascending: false });
  return data ?? [];
}

export async function addSighting(sighting: Omit<Sighting, 'id' | 'created_at'>) {
  const { error } = await supabase.from('sightings').insert(sighting);
  if (error) throw error;
}

export async function removeSighting(id: string) {
  const { error } = await supabase.from('sightings').delete().eq('id', id);
  if (error) throw error;
}

export async function isSighted(userId: string, birdId: string) {
  const { data } = await supabase
    .from('sightings')
    .select('id')
    .eq('user_id', userId)
    .eq('bird_id', birdId)
    .single();
  return !!data;
}